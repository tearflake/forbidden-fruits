<imp> := (IMP (PARAMS <atomic>+)? (VARS <atomic>+)? <stmt>+)

<stmt> := <assign>
        | <if>
        | <switch>
        | <while>
        | <foreach>
        | <return>

<assign> := (ASGN <var> <sexpr>)

<if> := (IF <sexpr> <sexpr> <stmt>+)

<switch> := (SWITCH <sexpr> (CASE <atomic> <stmt>+)+)

<while> := (WHILE <sexpr> <stmt>+)

<foreach> := (FOREACH <atomic> <sexpr> <stmt>+)

<return> := (RETURN <sexpr>)

